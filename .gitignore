Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# Node modules (if any)
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local

# Temporary files
*.tmp
*.temp

# Personal vault content (if using sample Brain)
Brain/00-Inbox/*.md
Brain/01-Sources/**/*.md
Brain/02-Permanent/*.md
Brain/03-MOCs/*.md
Brain/04-Output/**/*.md
Brain/05-Meta/Changelogs/*.md
Brain/AI Extracted Notes/*.md
Brain/Document Insights/**/*.md
!Brain/**/README.md
!Brain/**/_SAMPLE*.md
